# ============================================================
# Semaphore UI + Postgres — public configuration contract
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ---------- Semaphore image ----------
SEMAPHORE_IMAGE_TAG=latest

# ---------- Exposed port ----------
SEMAPHORE_PORT=3000

# ---------- Timezone ----------
TZ=Asia/Ho_Chi_Minh

# ---------- Postgres connection ----------
POSTGRES_DB=semaphore
POSTGRES_USER=semaphore
# POSTGRES_PASSWORD is read from secrets/postgres_password.txt via _FILE convention

# ---------- Public hostname (prod only) ----------
# Used by Caddy for TLS. Leave empty for local lab.
PUBLIC_HOSTNAME=

# ---------- Semaphore admin account ----------
SEMAPHORE_ADMIN=admin
SEMAPHORE_ADMIN_EMAIL=admin@example.com
SEMAPHORE_ADMIN_NAME=Administrator
# SEMAPHORE_ADMIN_PASSWORD is read from secrets/admin_password.txt

# ---------- Git integration ----------
# Optional: pre-configure a Git repository for Semaphore to clone.
# Leave empty and configure via Semaphore UI instead.
SEMAPHORE_GIT_CLIENT=cmd_git

# ---------- Local Docker Linux target ----------
# Optional: paste the content of your public SSH key here, then rebuild linux-target.
# Example:
# ANSIBLE_PUBKEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA... ansible-lab"
ANSIBLE_PUBKEY=

# ---------- Runner mode (optional) ----------
# Set to true to enable external runner registration
SEMAPHORE_RUNNER_REGISTRATION_TOKEN=

# ---------- Observability (optional profile) ----------
GRAFANA_ADMIN_PASSWORD=changeme
