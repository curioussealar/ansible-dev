<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Ansible Summary Report</title>
  <style>
    body { font-family: sans-serif; margin: 2rem; background: #f9f9f9; color: #333; }
    h1 { border-bottom: 2px solid #0066cc; color: #0066cc; }
    table { border-collapse: collapse; width: 100%; margin-top: 1rem; }
    th, td { border: 1px solid #ccc; padding: 8px 12px; text-align: left; }
    th { background: #0066cc; color: white; }
    tr:nth-child(even) { background: #f0f5ff; }
    .footer { margin-top: 2rem; font-size: 0.8rem; color: #888; }
  </style>
</head>
<body>
  <h1>Infrastructure Summary Report</h1>
  <p>Generated: {{ ansible_date_time.iso8601 | default('N/A') }}</p>
  <p>Total hosts in play: {{ all_hosts | length }}</p>

  <h2>Host Inventory</h2>
  <table>
    <tr>
      <th>Hostname</th>
      <th>OS</th>
      <th>IP Address</th>
      <th>CPU Cores</th>
      <th>RAM (MB)</th>
    </tr>
    {% for host in all_hosts %}
    <tr>
      <td>{{ host }}</td>
      <td>{{ hostvars[host]['ansible_distribution'] | default('N/A') }} {{ hostvars[host]['ansible_distribution_version'] | default('') }}</td>
      <td>{{ hostvars[host]['ansible_default_ipv4']['address'] | default('N/A') }}</td>
      <td>{{ hostvars[host]['ansible_processor_vcpus'] | default(hostvars[host]['ansible_processor_count'] | default('N/A')) }}</td>
      <td>{{ hostvars[host]['ansible_memtotal_mb'] | default('N/A') }}</td>
    </tr>
    {% endfor %}
  </table>

  <div class="footer">
    Generated by Ansible demo_report role | ansible-dev-lab
  </div>
</body>
</html>
