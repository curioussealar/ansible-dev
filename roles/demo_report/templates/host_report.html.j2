<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Ansible Report — {{ inventory_hostname }}</title>
  <style>
    body { font-family: sans-serif; margin: 2rem; background: #f9f9f9; color: #333; }
    h1 { border-bottom: 2px solid #0066cc; color: #0066cc; }
    table { border-collapse: collapse; width: 100%; margin-top: 1rem; }
    th, td { border: 1px solid #ccc; padding: 8px 12px; text-align: left; }
    th { background: #0066cc; color: white; }
    tr:nth-child(even) { background: #f0f5ff; }
    .label { font-weight: bold; width: 30%; }
    .footer { margin-top: 2rem; font-size: 0.8rem; color: #888; }
  </style>
</head>
<body>
  <h1>Host Report: {{ inventory_hostname }}</h1>
  <p>Generated: {{ ansible_date_time.iso8601 | default('N/A') }}</p>

  <h2>System Information</h2>
  <table>
    <tr><td class="label">Hostname</td><td>{{ ansible_hostname | default('N/A') }}</td></tr>
    <tr><td class="label">FQDN</td><td>{{ ansible_fqdn | default('N/A') }}</td></tr>
    <tr><td class="label">OS</td><td>{{ ansible_distribution | default('N/A') }} {{ ansible_distribution_version | default('') }}</td></tr>
    <tr><td class="label">Kernel</td><td>{{ ansible_kernel | default('N/A') }}</td></tr>
    <tr><td class="label">Architecture</td><td>{{ ansible_architecture | default('N/A') }}</td></tr>
    <tr><td class="label">CPU Cores</td><td>{{ ansible_processor_vcpus | default(ansible_processor_count | default('N/A')) }}</td></tr>
    <tr><td class="label">RAM (MB)</td><td>{{ ansible_memtotal_mb | default('N/A') }}</td></tr>
    <tr><td class="label">IPv4 Address</td><td>{{ ansible_default_ipv4.address | default('N/A') }}</td></tr>
    <tr><td class="label">Python Version</td><td>{{ ansible_python_version | default('N/A') }}</td></tr>
    <tr><td class="label">Uptime (sec)</td><td>{{ ansible_uptime_seconds | default('N/A') }}</td></tr>
  </table>

  <div class="footer">
    Generated by Ansible demo_report role | ansible-dev-lab
  </div>
</body>
</html>
